# ────────────────────────────────────────────────────────────────
# CryptoMint — Environment Variables
# Copy to `.env.local` and fill in the values.
# ────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────

# Deployed contract addresses (Sepolia)
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x...
NEXT_PUBLIC_FACTORY_CONTRACT_ADDRESS=0x...

# Alchemy API key — used by /api/rpc proxy and server-side metadata
ALCHEMY_API_KEY=

# Pinata JWT — used by /api/upload* routes to pin files to IPFS
PINATA_JWT=

# ── Optional ──────────────────────────────────────────────────

# WalletConnect project ID (cloud.walletconnect.com). If absent, WalletConnect is disabled.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# The Graph subgraph URL. If absent, data is fetched via RPC fallback.
NEXT_PUBLIC_SUBGRAPH_URL=

# NFTFavorites contract address. If absent, on-chain favorites are disabled.
NEXT_PUBLIC_FAVORITES_ADDRESS=
